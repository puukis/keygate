# Copy this file to .env.docker and edit values before running docker compose.

PORT=18790
KEYGATE_OPEN_CHAT_ON_START=false
KEYGATE_CHAT_URL=http://localhost:18790

# Keygate workspace inside container.
WORKSPACE_PATH=/workspace

# Provider defaults.
# - openai-codex: requires `codex` login in container (recommended command below)
# - openai/gemini: set LLM_API_KEY
# - ollama: set LLM_OLLAMA_HOST to your host/remote ollama endpoint
LLM_PROVIDER=openai-codex
LLM_MODEL=openai-codex/gpt-5.3
LLM_API_KEY=
LLM_OLLAMA_HOST=http://host.docker.internal:11434

SPICY_MODE_ENABLED=false
SPICY_MAX_OBEDIENCE_ENABLED=false

# Playwright MCP browser integration.
MCP_PLAYWRIGHT_VERSION=0.0.64
KEYGATE_AUTO_SETUP_MCP_BROWSER=true
KEYGATE_AUTO_SETUP_MCP_BROWSER_STRICT=false
BROWSER_DOMAIN_POLICY=none
BROWSER_DOMAIN_ALLOWLIST=
BROWSER_DOMAIN_BLOCKLIST=
BROWSER_TRACE_RETENTION_DAYS=7

# Optional channels/tools.
DISCORD_TOKEN=
DISCORD_PREFIX=!keygate
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
TAVILY_API_KEY=
