# Keygate Environment Variables (example)
# Copy to ~/.keygate/.env and fill in values
# Existing ~/.config/keygate installs are copied into ~/.keygate on first run
# when the new directory is missing, or when ~/.keygate only has bootstrap/cache
# files and no primary config yet. The old directory is left in place.

# LLM Provider: 'openai', 'gemini', 'ollama', or 'openai-codex'
LLM_PROVIDER=openai

# LLM Model examples:
# - openai: gpt-4o
# - gemini: gemini-1.5-pro
# - ollama: llama3
# - openai-codex: openai-codex/gpt-5.2
LLM_MODEL=gpt-4o

# API key (not used when LLM_PROVIDER=openai-codex)
LLM_API_KEY=your-api-key-here

# Spicy Mode: Enable unrestricted access (dangerous!)
# Set to 'true' only if you accepted the risk during installation
SPICY_MODE_ENABLED=false

# Spicy max-obedience toggle (spicy mode only, best-effort)
# Set to 'true' to aggressively reduce avoidable refusals
SPICY_MAX_OBEDIENCE_ENABLED=false

# Workspace path for safe mode file operations
WORKSPACE_PATH=~/keygate-workspace

# MCP browser policy: none, allowlist, or blocklist
BROWSER_DOMAIN_POLICY=none

# Comma-separated origins, used when policy=allowlist
BROWSER_DOMAIN_ALLOWLIST=

# Comma-separated origins, used when policy=blocklist
BROWSER_DOMAIN_BLOCKLIST=

# Retention in days for browser run artifacts (screenshots, traces)
BROWSER_TRACE_RETENTION_DAYS=7

# Pinned Playwright MCP version for codex mcp provisioning
MCP_PLAYWRIGHT_VERSION=0.0.64

# Automatically open chat UI when running `keygate` (default true)
KEYGATE_OPEN_CHAT_ON_START=true

# Chat UI URL to open on startup
KEYGATE_CHAT_URL=http://localhost:18789

# Discord bot token (optional)
DISCORD_TOKEN=

# Discord command prefix (optional)
DISCORD_PREFIX=!keygate

# Discord DM trust policy: pairing|open|closed (default pairing)
DISCORD_DM_POLICY=pairing

# Discord DM allowlist user IDs (comma-separated, optional, '*' allows all)
DISCORD_ALLOW_FROM=

# Slack DM trust policy: pairing|open|closed (default pairing)
SLACK_DM_POLICY=pairing

# Slack DM allowlist user IDs (comma-separated, optional, '*' allows all)
SLACK_ALLOW_FROM=

# Approval memory TTL in hours for allow_always (default: 168)
KEYGATE_APPROVAL_TTL_HOURS=168

# Web search API key (optional, for Tavily)
TAVILY_API_KEY=
